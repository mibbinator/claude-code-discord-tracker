{
  "_comment": "Merge the hooks block below into %USERPROFILE%\\.claude\\settings.json. Replace YOUR_DISCORD_USER_ID with your numeric Discord user ID (or remove ' -UserId YOUR_DISCORD_USER_ID' from a hook to post without pinging). The activity hooks need no user ID (that feed never pings). The Notification matcher whitelists only the notification_type values that mean Claude needs you (permission prompts, MCP elicitation dialogs, and the idle 'waiting for your input' prompt); there is intentionally NO Stop hook because turn-end is not a needs-input signal.",
  "hooks": {
    "Notification": [
      { "matcher": "permission_prompt|worker_permission_prompt|idle_prompt|elicitation_dialog|elicitation_url_dialog", "hooks": [ { "type": "command", "shell": "powershell", "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:USERPROFILE\\.claude\\notify-discord.ps1\" -Event Notification -UserId YOUR_DISCORD_USER_ID", "async": true } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "shell": "powershell", "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:USERPROFILE\\.claude\\notify-discord-activity.ps1\" -Kind UserPrompt", "async": true } ] }
    ],
    "SubagentStart": [
      { "hooks": [ { "type": "command", "shell": "powershell", "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:USERPROFILE\\.claude\\notify-discord-activity.ps1\" -Kind SubagentStart", "async": true } ] }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "command", "shell": "powershell", "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:USERPROFILE\\.claude\\notify-discord-activity.ps1\" -Kind SubagentStop", "async": true } ] }
    ],
    "PostToolUse": [
      { "matcher": "Workflow", "hooks": [ { "type": "command", "shell": "powershell", "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:USERPROFILE\\.claude\\notify-discord-activity.ps1\" -Kind Workflow", "async": true } ] }
    ],
    "MessageDisplay": [
      { "hooks": [ { "type": "command", "shell": "powershell", "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:USERPROFILE\\.claude\\notify-discord-activity.ps1\" -Kind Message", "async": true } ] }
    ]
  }
}
